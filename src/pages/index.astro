---
import BaseLayout from "../layouts/BaseLayout.astro";
import MarketingIcon from "../components/ui/MarketingIcon.astro";
import "@splidejs/splide/css/core";

const features = [
  {
    icon: "glass",
    tone: "blue",
    title: "VITRAGE",
    subtitle: "SUR MESURE"
  },
  {
    icon: "repair",
    tone: "red",
    title: "REPARATION",
    subtitle: "RAPIDE"
  },
  {
    icon: "thermo",
    tone: "blue",
    title: "ISOLATION",
    subtitle: "THERMIQUE"
  }
] as const;

const trustItems = [
  {
    icon: "quality",
    label: "TRAVAIL DE QUALITE"
  },
  {
    icon: "clock",
    label: "DISPONIBLE 24H/24"
  },
  {
    icon: "shield",
    label: "SECURITE GARANTIE"
  },
  {
    icon: "people",
    label: "SATISFACTION CLIENT"
  }
] as const;

const showcaseSlides = [
  {
    eyebrow: "Facade vitree",
    title: "Une entree vitree qui impose tout de suite le niveau.",
    description:
      "Grandes surfaces, profils sombres et reflets nets pour donner a la facade une presence tres premium.",
    image: "/carrousel/facade-vitree.jpeg",
    alt: "Facade contemporaine entierement vitree avec entree centrale",
    tags: ["Facade", "Grand format", "Finition premium"]
  },
  {
    eyebrow: "Cloison de bureau",
    title: "Des separations en verre qui laissent circuler la lumiere.",
    description:
      "Une ligne tres propre, une sensation d'espace intacte et une lecture plus elegante des volumes interieurs.",
    image: "/carrousel/cloison-bureau.jpeg",
    alt: "Bureau ferme par une grande cloison vitree coulissante",
    tags: ["Cloison", "Lumiere", "Minimal"]
  },
  {
    eyebrow: "Paroi de douche",
    title: "Une salle d'eau plus nette, plus sobre, plus graphique.",
    description:
      "Verre, ferrures noires et pose precise pour faire monter la finition sans alourdir l'espace.",
    image: "/carrousel/paroi-douche.jpeg",
    alt: "Douche moderne fermee par une paroi vitree encadree de noir",
    tags: ["Salle de bain", "Pose precise", "Design"]
  },
  {
    eyebrow: "Garde-corps vitres",
    title: "De la securite sans casser la vue ni la legerete.",
    description:
      "Des lignes discretes, une transparence continue et un rendu tres propre pour les terrasses et les etages.",
    image: "/carrousel/garde-corps-vitre.jpeg",
    alt: "Terrasse contemporaine avec garde-corps entierement vitre",
    tags: ["Terrasse", "Securite", "Transparence"]
  },
  {
    eyebrow: "Escalier en verre",
    title: "Une piece signature qui capte tout de suite le regard.",
    description:
      "Marches, garde-corps et baies travaillent ensemble pour donner une impression d'espace tres spectaculaire.",
    image: "/carrousel/escalier-verre.jpeg",
    alt: "Interieur lumineux avec escalier et garde-corps en verre",
    tags: ["Escalier", "Effet waouh", "Architecture"]
  }
] as const;

const serviceFocus = [
  {
    icon: "glass",
    title: "Vitrage sur mesure",
    description:
      "Decoupe, faconnage et pose adaptes aux dimensions, aux usages et aux contraintes de chaque ouverture."
  },
  {
    icon: "thermo",
    title: "Isolation performante",
    description:
      "Double vitrage, optimisation thermique et reduction des deperditions pour gagner en confort au quotidien."
  },
  {
    icon: "shield",
    title: "Securisation rapide",
    description:
      "Remplacement apres bris, mise en securite et finitions fiables pour proteger les lieux sans attendre."
  }
] as const;
---

<BaseLayout
  title="UNIVERS GLASS"
  description="UNIVERS GLASS, la transparence au service de vos projets."
>
  <main class="home-shell">
    <section class="hero-card">
      <div class="hero-main">
        <div class="hero-copy">
          <div class="hero-copy__bg" aria-hidden="true"></div>

          <a class="brand-lockup" href="/" aria-label="Vitrerie Pro">
            <svg viewBox="0 0 54 74" aria-hidden="true">
              <path
                d="M7 7.5 28 1v65L7 72.5Z"
                fill="none"
                stroke="currentColor"
                stroke-width="5"
              ></path>
              <path d="M34 7.5 47 4v64l-13 3.5Z" fill="currentColor"></path>
            </svg>

            <span class="brand-copy">
              <strong>UNIVERS GLASS</strong>
              <span>LA TRANSPARENCE AU SERVICE DE VOS PROJETS</span>
            </span>
          </a>

          <h1 class="hero-title">
            <span>LA TRANSPARENCE</span>
            <span class="hero-title--accent">AU SERVICE DE</span>
            <span>VOS PROJETS</span>
          </h1>

          <span class="hero-rule" aria-hidden="true"></span>

          <p class="hero-description">
            Specialiste en vitrerie moderne : installation, reparation et sur
            mesure.
          </p>

          <div class="feature-list">
            {
              features.map((feature) => (
                <div class={`feature-item feature-item--${feature.tone}`}>
                  <span class="feature-item__icon">
                    <MarketingIcon name={feature.icon} />
                  </span>

                  <span class="feature-item__copy">
                    <span>{feature.title}</span>
                    <span>{feature.subtitle}</span>
                  </span>
                </div>
              ))
            }
          </div>

          <div class="hero-actions">
            <a class="hero-button hero-button--blue" href="/devis">
              <span class="hero-button__icon">
                <MarketingIcon name="quote" />
              </span>

              <span class="hero-button__copy">
                <small>DEMANDEZ VOTRE</small>
                <strong>DEVIS GRATUIT</strong>
              </span>
            </a>

            <a class="hero-button hero-button--red" href="/intervention-rapide">
              <span class="hero-button__icon">
                <MarketingIcon name="arrow" />
              </span>

              <span class="hero-button__copy">
                <small>INTERVENTION RAPIDE</small>
                <strong>ET PROFESSIONNELLE</strong>
              </span>
            </a>
          </div>
        </div>

        <div class="hero-media">
          <img
            src="/fonds.png"
            alt="Maison moderne avec large baie vitree"
            loading="eager"
          />
        </div>
      </div>

      <div class="hero-bottom">
        <div class="hero-bottom__items">
          {
            trustItems.map((item) => (
              <div class="trust-item">
                <span class="trust-item__icon">
                  <MarketingIcon name={item.icon} />
                </span>
                <span class="trust-item__label">{item.label}</span>
              </div>
            ))
          }
        </div>

        <a class="contact-panel" href="/contact">
          <span class="contact-panel__icon">
            <MarketingIcon name="mail" />
          </span>

          <span class="contact-panel__copy">
            <strong>CONTACTEZ-NOUS</strong>
            <small>Nous sommes a votre ecoute</small>
          </span>
        </a>
      </div>
    </section>

    <section class="showcase-section" data-animate="showcase">
      <div class="showcase-heading">
        <span class="section-kicker">SIGNATURE VISUELLE</span>
        <h2>Des realisations qui respirent la lumiere.</h2>
      </div>

      <div class="showcase-stage">
        <div
          class="splide showcase-splide js-showcase-slider"
          aria-label="Realisations vitrees mises en avant"
        >
          <div class="splide__track">
            <ul class="splide__list">
              {
                showcaseSlides.map((slide) => (
                  <li class="splide__slide">
                    <article
                      class={`showcase-slide${slide.image === "/carrousel/paroi-douche.jpeg" ? " showcase-slide--paroi-douche" : ""}`}
                      data-lift-card
                    >
                      <div class="showcase-slide__media">
                        <img src={slide.image} alt={slide.alt} loading="lazy" />
                      </div>

                      <div class="showcase-slide__content">
                        <span class="showcase-slide__eyebrow">
                          {slide.eyebrow}
                        </span>
                        <h3>{slide.title}</h3>
                        <p>{slide.description}</p>

                        <div class="showcase-slide__tags">
                          {slide.tags.map((tag) => <span>{tag}</span>)}
                        </div>
                      </div>
                    </article>
                  </li>
                ))
              }
            </ul>
          </div>

          <div class="splide__arrows showcase-splide__arrows">
            <button
              class="splide__arrow splide__arrow--prev"
              type="button"
              aria-label="Slide precedente"
            >
              <svg viewBox="0 0 40 40" aria-hidden="true">
                <path
                  d="m15.5 8.5 11 11-11 11"
                  fill="none"
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="3.4"
                ></path>
              </svg>
            </button>

            <button
              class="splide__arrow splide__arrow--next"
              type="button"
              aria-label="Slide suivante"
            >
              <svg viewBox="0 0 40 40" aria-hidden="true">
                <path
                  d="m15.5 8.5 11 11-11 11"
                  fill="none"
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="3.4"
                ></path>
              </svg>
            </button>
          </div>
        </div>
      </div>
    </section>

    <section class="signature-section" data-animate="signature">
      <div class="signature-copy">
        <span class="section-kicker">EXPERTISE VITRERIE</span>
        <h2>Des solutions techniques pensees pour une vitrerie professionnelle.</h2>
        <p>
          Vitrage isolant, remplacement apres casse, pose sur mesure et mise en
          securite: chaque intervention vise la precision, la durabilite et la
          qualite de finition.
        </p>
      </div>

      <div class="signature-grid">
        {
          serviceFocus.map((item) => (
            <article class="signature-card" data-lift-card>
              <span class="signature-card__icon">
                <MarketingIcon name={item.icon} />
              </span>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </article>
          ))
        }
      </div>
    </section>
  </main>

  <script>
    import "../scripts/home-animations";
  </script>

  <style>
    @import url("https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap");

    :global(body) {
      background:
        radial-gradient(circle at top left, rgba(81, 152, 228, 0.22), transparent 30%),
        linear-gradient(180deg, #dce8f4 0%, #eef4fb 100%);
    }

    .home-shell {
      width: min(100%, 1440px);
      min-height: 100vh;
      margin: 0 auto;
      padding:
        clamp(0.5rem, 1.1vw, 1rem)
        clamp(0.5rem, 1.1vw, 1rem)
        clamp(0.55rem, 1vw, 0.85rem);
      display: grid;
      align-content: start;
      gap: clamp(1rem, 2vw, 1.65rem);
      font-family: "Montserrat", "Segoe UI", Arial, sans-serif;
    }

    .hero-card {
      width: 100%;
      min-height: calc(100vh - clamp(0.5rem, 1.1vw, 1rem));
      display: grid;
      grid-template-rows: minmax(0, 1fr) auto;
      background: #ffffff;
      box-shadow: 0 24px 70px rgba(16, 49, 93, 0.14);
      overflow: hidden;
    }

    .hero-main {
      position: relative;
      display: grid;
      grid-template-columns: minmax(0, 0.88fr) minmax(0, 1.12fr);
      min-height: min(72vh, 640px);
      background:
        radial-gradient(circle at 10% 18%, rgba(82, 146, 221, 0.2), rgba(82, 146, 221, 0) 28%),
        linear-gradient(90deg, #f6fbff 0%, #f8fbff 55%, #e1edf8 55%, #d5e5f3 100%);
    }

    .hero-copy,
    .hero-media {
      position: relative;
      min-width: 0;
    }

    .hero-copy {
      z-index: 3;
      padding:
        clamp(1.35rem, 2.4vw, 2.1rem)
        clamp(1.45rem, 2.8vw, 2.2rem)
        clamp(1.2rem, 2vw, 1.7rem)
        clamp(1.5rem, 3vw, 2.3rem);
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
    }

    .hero-copy__bg {
      position: absolute;
      inset: 0 -11rem 0 0;
      background:
        linear-gradient(90deg, rgba(248, 252, 255, 0.98) 0%, rgba(250, 252, 255, 0.98) 78%, rgba(241, 247, 252, 0.92) 100%);
      clip-path: polygon(0 0, 78% 0, 100% 50%, 78% 100%, 0 100%);
      z-index: -1;
      pointer-events: none;
    }

    .brand-lockup {
      width: fit-content;
      display: inline-flex;
      align-items: flex-start;
      gap: 0.8rem;
      margin-bottom: clamp(1rem, 2.2vw, 1.55rem);
      color: #145fbc;
    }

    .brand-lockup svg {
      width: clamp(2rem, 2.2vw, 2.5rem);
      height: auto;
      flex: none;
    }

    .brand-copy {
      display: grid;
      gap: 0.15rem;
      line-height: 1;
    }

    .brand-copy strong {
      color: #185eb4;
      font-size: clamp(1.45rem, 1.9vw, 2rem);
      font-weight: 800;
      letter-spacing: -0.03em;
    }

    .brand-copy span {
      max-width: 18rem;
      color: #172847;
      font-size: clamp(0.6rem, 0.68vw, 0.76rem);
      line-height: 1.15;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .hero-title {
      margin-bottom: 0;
      color: #155fbc;
      font-size: clamp(2.2rem, 4vw, 4rem);
      line-height: 0.94;
      font-weight: 800;
      letter-spacing: -0.045em;
      text-transform: uppercase;
    }

    .hero-title span {
      display: block;
      white-space: nowrap;
    }

    .hero-title--accent {
      color: #e31b23;
    }

    .hero-rule {
      width: 3.6rem;
      height: 0.2rem;
      margin: 0.95rem 0 0.8rem;
      border-radius: 999px;
      background: #e31b23;
    }

    .hero-description {
      max-width: 27rem;
      margin-bottom: 1rem;
      color: #1b3054;
      font-size: clamp(0.88rem, 0.95vw, 1rem);
      line-height: 1.38;
      font-weight: 500;
    }

    .feature-list {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem 1rem;
      margin-bottom: 1rem;
    }

    .feature-item {
      display: grid;
      grid-template-columns: auto 1fr;
      align-items: center;
      gap: 0.5rem;
      min-width: 7.8rem;
    }

    .feature-item__icon {
      width: 2.45rem;
      height: 2.45rem;
      display: grid;
      place-items: center;
      border-radius: 50%;
      color: #ffffff;
      box-shadow: 0 10px 18px rgba(14, 58, 119, 0.14);
    }

    .feature-item--blue .feature-item__icon {
      background: #165fbc;
    }

    .feature-item--red .feature-item__icon {
      background: #e31b23;
    }

    .feature-item__copy {
      display: grid;
      gap: 0.08rem;
      font-size: 0.64rem;
      line-height: 1.06;
      font-weight: 800;
      letter-spacing: 0.03em;
      text-transform: uppercase;
    }

    .feature-item--blue .feature-item__copy {
      color: #1459ad;
    }

    .feature-item--red .feature-item__copy {
      color: #d81b22;
    }

    .hero-actions {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.75rem;
      max-width: 32rem;
    }

    .hero-button {
      display: grid;
      grid-template-columns: auto 1fr;
      align-items: center;
      gap: 0.7rem;
      min-width: 0;
      min-height: 3.85rem;
      padding: 0.5rem 0.95rem 0.5rem 0.62rem;
      border-radius: 1rem;
      color: #ffffff;
      box-shadow: 0 14px 22px rgba(16, 49, 93, 0.18);
    }

    .hero-button--blue {
      background: linear-gradient(135deg, #236fd2 0%, #155fbc 100%);
      --button-accent: #165fbc;
    }

    .hero-button--red {
      background: linear-gradient(135deg, #ef2129 0%, #d81720 100%);
      --button-accent: #e31b23;
    }

    .hero-button__icon {
      width: 2.35rem;
      height: 2.35rem;
      display: grid;
      place-items: center;
      border-radius: 50%;
      background: #ffffff;
      color: var(--button-accent);
      box-shadow: inset 0 0 0 1px rgba(15, 45, 92, 0.08);
    }

    .hero-button__copy {
      display: grid;
      gap: 0.12rem;
      line-height: 1;
      text-transform: uppercase;
    }

    .hero-button__copy small {
      font-size: 0.61rem;
      font-weight: 700;
      letter-spacing: 0.04em;
    }

    .hero-button__copy strong {
      font-size: 0.94rem;
      font-weight: 800;
      letter-spacing: -0.03em;
    }

    .hero-media {
      z-index: 1;
      overflow: hidden;
      min-height: 100%;
      background: #d8e7f5;
    }

    .hero-media::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0)),
        linear-gradient(90deg, rgba(255, 255, 255, 0.18), rgba(255, 255, 255, 0));
      pointer-events: none;
    }

    .hero-media::after {
      content: "";
      position: absolute;
      left: -3.2rem;
      bottom: 0;
      width: 13rem;
      height: 7rem;
      background: rgba(255, 255, 255, 0.96);
      clip-path: polygon(100% 100%, 0% 100%, 100% 100%);
      pointer-events: none;
    }

    .hero-media img {
      width: 100%;
      height: 100%;
      display: block;
      object-fit: cover;
      object-position: 68% center;
    }

    .hero-bottom {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: stretch;
      background: #11468d;
      color: #ffffff;
    }

    .hero-bottom__items {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .trust-item {
      min-height: 3.95rem;
      padding: 0.55rem 0.8rem;
      display: flex;
      align-items: center;
      gap: 0.55rem;
      border-right: 1px solid rgba(255, 255, 255, 0.2);
    }

    .trust-item__icon {
      width: 2rem;
      height: 2rem;
      display: grid;
      place-items: center;
      flex: none;
      border-radius: 50%;
      border: 1px solid rgba(255, 255, 255, 0.36);
      color: #ffffff;
    }

    .trust-item__label {
      font-size: 0.65rem;
      line-height: 1.15;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .contact-panel {
      position: relative;
      min-width: 22.5rem;
      margin-top: -0.65rem;
      padding: 0.8rem 1.35rem 0.8rem 0.95rem;
      display: grid;
      grid-template-columns: auto 1fr;
      align-items: center;
      gap: 0.7rem;
      background: linear-gradient(135deg, #ef232b 0%, #de1820 100%);
      color: #ffffff;
      clip-path: polygon(2rem 0, 100% 0, 100% 100%, 0 100%, 0 58%);
      box-shadow: 0 14px 22px rgba(132, 15, 23, 0.24);
    }

    .contact-panel::after {
      content: "";
      position: absolute;
      left: -1.4rem;
      bottom: 0;
      width: 2rem;
      height: 100%;
      background: #11468d;
      clip-path: polygon(100% 0, 0 100%, 100% 100%);
    }

    .contact-panel__icon {
      position: relative;
      z-index: 1;
      width: 3rem;
      height: 3rem;
      display: grid;
      place-items: center;
      border-radius: 50%;
      background: #ffffff;
      color: #de1820;
      box-shadow: 0 10px 18px rgba(95, 9, 14, 0.18);
    }

    .contact-panel__copy {
      position: relative;
      z-index: 1;
      display: grid;
      gap: 0.16rem;
      text-transform: uppercase;
    }

    .contact-panel__copy strong {
      font-size: 1rem;
      line-height: 1;
      font-weight: 800;
      letter-spacing: -0.03em;
    }

    .contact-panel__copy small {
      font-size: 0.74rem;
      line-height: 1.18;
      font-weight: 500;
      text-transform: none;
    }

    .section-kicker {
      display: inline-flex;
      width: fit-content;
      align-items: center;
      gap: 0.55rem;
      color: #165fbc;
      font-size: 0.78rem;
      font-weight: 800;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }

    .section-kicker::before {
      content: "";
      width: 2.6rem;
      height: 1px;
      background: currentColor;
      opacity: 0.4;
    }

    .showcase-section,
    .signature-section {
      position: relative;
      overflow: hidden;
      border-radius: 2rem;
      box-shadow: 0 24px 70px rgba(16, 49, 93, 0.12);
    }

    .showcase-section {
      padding:
        clamp(1.4rem, 3vw, 2.4rem)
        clamp(1.4rem, 3vw, 2.4rem)
        clamp(0.75rem, 1.6vw, 1.05rem);
      background:
        radial-gradient(circle at 0% 0%, rgba(35, 111, 210, 0.16), rgba(35, 111, 210, 0) 28%),
        linear-gradient(135deg, #f8fbff 0%, #eef5fb 52%, #e2edf7 100%);
      border: 1px solid rgba(21, 95, 188, 0.08);
    }

    .signature-section {
      padding: clamp(1.35rem, 2.8vw, 2.2rem);
      background:
        radial-gradient(circle at top right, rgba(227, 27, 35, 0.12), rgba(227, 27, 35, 0) 28%),
        linear-gradient(135deg, #103a73 0%, #11468d 54%, #1e5fb3 100%);
      color: #ffffff;
    }

    .showcase-heading,
    .signature-copy {
      position: relative;
      z-index: 2;
    }

    .showcase-heading {
      max-width: 100%;
    }

    .signature-copy {
      max-width: 40rem;
    }

    .showcase-heading h2,
    .signature-copy h2 {
      margin: 0.8rem 0 0.75rem;
      font-size: clamp(1.7rem, 2.5vw, 2.55rem);
      line-height: 0.96;
      letter-spacing: -0.045em;
      text-transform: uppercase;
    }

    .showcase-heading h2 {
      color: #123b72;
      white-space: nowrap;
    }

    .signature-copy h2 {
      color: #ffffff;
    }

    .showcase-heading p,
    .signature-copy p {
      margin: 0;
      font-size: clamp(0.95rem, 1vw, 1.05rem);
      line-height: 1.65;
    }

    .showcase-heading p {
      color: #27456e;
    }

    .signature-copy p {
      max-width: 34rem;
      color: rgba(255, 255, 255, 0.78);
    }

    .showcase-stage {
      position: relative;
      width: min(100%, 74rem);
      margin: clamp(1.2rem, 2.2vw, 1.8rem) auto 0;
    }

    .showcase-splide {
      position: relative;
      z-index: 2;
      visibility: visible;
      display: grid;
      gap: 0;
